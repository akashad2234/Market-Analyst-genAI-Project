# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# API Keys (required)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# LLM Narrative Generation (optional, disabled by default)
# Set LLM_ENABLED=true to get AI-generated narrative paragraphs
# in addition to rule-based explanations for each agent.
# ---------------------------------------------------------------------------
# LLM_ENABLED=false
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash
# LLM_TEMPERATURE=0.3

# ---------------------------------------------------------------------------
# Scoring weights (must sum to 1.0, optional overrides)
# ---------------------------------------------------------------------------
# FUNDAMENTAL_WEIGHT=0.4
# TECHNICAL_WEIGHT=0.4
# SENTIMENT_WEIGHT=0.2

# ---------------------------------------------------------------------------
# Scoring thresholds (JSON array of [min_score, label] pairs, sorted desc)
# ---------------------------------------------------------------------------
# SCORING_THRESHOLDS=[[80,"Strong Buy"],[60,"Buy"],[40,"Hold"],[0,"Avoid"]]

# ---------------------------------------------------------------------------
# Data source: Yahoo Finance (optional)
# Retries with backoff on rate limit (Too Many Requests)
# ---------------------------------------------------------------------------
# YAHOO_HISTORY_PERIOD_DAYS=365
# YAHOO_HISTORY_INTERVAL=1d
# YAHOO_RETRY_ATTEMPTS=3
# YAHOO_RETRY_DELAY_BASE=2.0

# ---------------------------------------------------------------------------
# Data source: DuckDuckGo (optional)
# Increase timeout/retries if searches fail or time out
# ---------------------------------------------------------------------------
# DDG_MAX_RESULTS=10
# DDG_RATE_LIMIT_SECONDS=2.0
# DDG_CACHE_SIZE=128
# DDG_TIMEOUT=30
# DDG_RETRY_ATTEMPTS=2

# ---------------------------------------------------------------------------
# Rate limiting: delay between analyzing multiple tickers (portfolio/comparison)
# Helps avoid Yahoo and DuckDuckGo rate limits
# ---------------------------------------------------------------------------
# DELAY_BETWEEN_TICKERS_SECONDS=3.0

# ---------------------------------------------------------------------------
# Server (optional)
# ---------------------------------------------------------------------------
# API_HOST=0.0.0.0
# API_PORT=8000
# CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Database / Cache (optional)
# SQLite database for caching analysis results and storing history.
# Cache key = ticker. On cache hit, LLM narrative is still generated fresh.
# ---------------------------------------------------------------------------
# DB_PATH=data/market_analyst.db
# CACHE_TTL_ANALYSIS=900

# ---------------------------------------------------------------------------
# Logging (optional): DEBUG, INFO, WARNING, ERROR
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO
